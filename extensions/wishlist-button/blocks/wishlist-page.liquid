<script>
  (function() {
    const urlParams = new URLSearchParams(window.location.search);
    const sharedListId = urlParams.get('list');
    const isSharedView = !!sharedListId;
    let userId = sharedListId;

    if (!isSharedView) {
      userId = localStorage.getItem("wishlist_user");
      if (!userId) {
        userId = 'temp-' + Date.now();
        localStorage.setItem("wishlist_user", userId);
      }
      document.getElementById('wp-actions').style.display = 'flex';
    } else {
      document.getElementById('wp-title').textContent = "Shared Wishlist";
      document.getElementById('wp-subtitle').textContent = "Someone shared their wishlist with you";
    }

    const grid = document.getElementById('wp-grid');
    const loading = document.getElementById('wp-loading');
    const emptyState = document.getElementById('wp-empty');

    function showToast(message) {
      const toast = document.getElementById('wp-toast');
      toast.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>${message}`;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    async function fetchWishlist() {
      try {
        const response = await fetch(`/apps/wishlist?userId=${userId}`);
        const data = await response.json();
        loading.style.display = 'none';
        if (!Array.isArray(data) || data.length === 0) {
          emptyState.style.display = 'block';
          return;
        }
        grid.style.display = 'grid';
        renderItems(data);
      } catch (err) {
        loading.innerHTML = '<p style="color:#999;text-align:center;padding:3rem 0;">Failed to load wishlist. Please try again.</p>';
        console.error(err);
      }
    }

    function renderItems(items) {
      grid.innerHTML = '';
      items.forEach((item, i) => {
        if (!item.product) return;
        const price = item.product.priceRangeV2?.minVariantPrice;
        const priceStr = price ? parseFloat(price.amount).toFixed(2) + ' ' + price.currencyCode : '';
        const imgUrl = item.product.featuredImage?.url || '';
        const productUrl = `/products/${item.product.handle}`;

        const card = document.createElement('div');
        card.className = 'wp-card';
        card.style.animationDelay = (i * 0.07) + 's';

        const noteHtml = isSharedView
          ? (item.note ? `<div class="wp-note-display"><span class="wp-note-emoji">📝</span><span class="wp-note-text">${item.note}</span></div>` : '')
          : `
            <div class="wp-note-area">
              <div class="wp-note-display" style="display:${item.note ? 'flex' : 'none'};">
                <span class="wp-note-emoji">📝</span>
                <span class="wp-note-text note-text">${item.note || ''}</span>
                <button class="wp-note-edit-btn btn-edit">Edit</button>
              </div>
              <button class="wp-note-trigger btn-trigger" style="display:${item.note ? 'none' : 'flex'};">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add a personal note…
              </button>
              <div class="wp-note-form" style="display:none;">
                <textarea class="wp-note-textarea" placeholder="e.g. Size M, for birthday 🎁, want in blue…" rows="4"></textarea>
                <div class="wp-note-form-actions">
                  <button class="wp-note-save-btn btn-save">Save Note</button>
                  <button class="wp-note-cancel-btn btn-cancel">Cancel</button>
                </div>
              </div>
            </div>`;

        card.innerHTML = `
          <div class="wp-img-wrap">
            <a href="${productUrl}">
              ${imgUrl ? `<img src="${imgUrl}" alt="${item.product.title}" class="wp-image" loading="lazy" />` : '<div class="wp-image" style="display:flex;align-items:center;justify-content:center;color:#ccc;font-size:3rem;">🖼</div>'}
            </a>
          </div>
          <div class="wp-card-content">
            <a href="${productUrl}" class="wp-prod-title">${item.product.title}</a>
            ${priceStr ? `<div class="wp-prod-price">${priceStr}</div>` : ''}
            ${noteHtml}
            ${!isSharedView ? `
            <div class="wp-card-actions">
              <button class="wp-add-to-cart-btn btn-add-cart" data-variant-id="${item.product.variants?.nodes[0]?.id?.split('/').pop() || ''}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Add to Cart
              </button>
              <button class="wp-remove-btn btn-remove" aria-label="Remove from wishlist">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/>
                </svg>
              </button>
            </div>` : `<a href="${productUrl}" class="wp-shop-btn" style="margin-top:1rem;">Shop Now</a>`}
          </div>`;

        if (!isSharedView) {
          const noteDisplay = card.querySelector('.wp-note-display');
          const noteTextEl  = card.querySelector('.note-text');
          const noteForm    = card.querySelector('.wp-note-form');
          const noteTrigger = card.querySelector('.btn-trigger');
          const textarea    = card.querySelector('.wp-note-textarea');

          function showForm() {
            noteDisplay.style.display = 'none';
            noteTrigger && (noteTrigger.style.display = 'none');
            noteForm.style.display = 'flex';
            textarea.focus();
          }
          function showTrigger() {
            noteForm.style.display = 'none';
            noteDisplay.style.display = 'none';
            noteTrigger && (noteTrigger.style.display = 'flex');
          }
          function showNote() {
            noteForm.style.display = 'none';
            noteTrigger && (noteTrigger.style.display = 'none');
            noteDisplay.style.display = 'flex';
          }

          if (noteTrigger) noteTrigger.onclick = () => { textarea.value = ''; showForm(); };

          card.querySelector('.btn-edit').onclick = () => {
            textarea.value = item.note || '';
            showForm();
          };

          const cancelBtn = card.querySelector('.btn-cancel');
          if (cancelBtn) cancelBtn.onclick = () => {
            if (item.note) showNote(); else showTrigger();
          };

          card.querySelector('.btn-save').onclick = async () => {
            const newNote = textarea.value.trim();
            const saveBtn = card.querySelector('.btn-save');
            saveBtn.textContent = 'Saving…';
            try {
              await fetch("/apps/wishlist", {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ productId: item.productId, userId, action: 'UPDATE', note: newNote })
              });
              item.note = newNote;
              if (newNote) {
                noteTextEl.textContent = newNote;
                showNote();
              } else {
                showTrigger();
              }
            } catch (e) { alert("Failed to save note"); }
            finally { saveBtn.textContent = 'Save Note'; }
          };

          card.querySelector('.btn-remove').onclick = async () => {
            const rmBtn = card.querySelector('.btn-remove');
            rmBtn.style.opacity = '0.5';
            rmBtn.disabled = true;
            card.style.transition = 'all 0.4s ease';
            try {
              await fetch("/apps/wishlist", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ productId: item.productId, userId, action: 'REMOVE' })
              });
              card.style.opacity = '0';
              card.style.transform = 'scale(0.9) translateY(10px)';
              setTimeout(() => {
                card.remove();
                if (grid.children.length === 0) {
                  grid.style.display = 'none';
                  emptyState.style.display = 'block';
                }
              }, 400);
            } catch (e) {
              rmBtn.style.opacity = '1';
              rmBtn.disabled = false;
              alert("Failed to remove item");
            }
          };

          card.querySelector('.btn-add-cart').onclick = async () => {
            const addBtn = card.querySelector('.btn-add-cart');
            const variantId = addBtn.getAttribute('data-variant-id');
            if (!variantId) {
              alert("Sorry, this product doesn't have an available variant.");
              return;
            }

            const originalHtml = addBtn.innerHTML;
            addBtn.innerHTML = 'Adding...';
            addBtn.disabled = true;

            try {
              console.log("[Wishlist] Adding to cart, variantId:", variantId);
              const root = window.Shopify?.routes?.root || '/';
              const cartUrl = (root.endsWith('/') ? root : root + '/') + 'cart/add.js';
              
              const res = await fetch(cartUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
              });

              const responseJson = await response.json();

              if (response.ok) {
                addBtn.innerHTML = '✓ Added!';
                addBtn.style.background = '#22c55e';
                showToast("Product added to cart!");
                // Let the button reset after 2 seconds
                setTimeout(() => {
                  addBtn.innerHTML = originalHtml;
                  addBtn.style.background = '';
                  addBtn.disabled = false;
                }, 2000);
              } else {
                throw new Error(responseJson.description || "Failed to add to cart");
              }
            } catch (err) {
              addBtn.innerHTML = 'Error';
              console.error(err);
              alert(err.message || "Couldn't add to cart. Product might be out of stock.");
              setTimeout(() => { addBtn.innerHTML = originalHtml; addBtn.disabled = false; }, 2000);
            }
          };
        }

        grid.appendChild(card);
      });
    }

    // ── Share Modal Logic ──────────────────────────────
    const shareBtn = document.getElementById('wp-share-btn');
    const shareModal = document.getElementById('wp-share-modal');
    const modalClose = document.getElementById('wp-modal-close');
    const shareUrlInput = document.getElementById('wp-share-url-input');
    const copyBtn = document.getElementById('wp-copy-btn');
    const copyHint = document.getElementById('wp-copy-hint');

    function openShareModal() {
      const shareUrl = new URL(window.location.href);
      shareUrl.searchParams.set('list', userId);
      const shareUrlStr = shareUrl.toString();

      shareUrlInput.value = shareUrlStr;
      shareModal.style.display = 'flex';
      // Auto-select the URL for easy copy
      setTimeout(() => { shareUrlInput.select(); shareUrlInput.setSelectionRange(0, 99999); }, 100);

      // Try auto-copy silently
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(shareUrlStr)
          .then(() => { copyHint.textContent = '✓ Link auto-copied to clipboard!'; copyHint.style.color = '#22c55e'; })
          .catch(() => { copyHint.textContent = 'Click "Copy" or select all and copy manually.'; copyHint.style.color = '#888'; });
      } else {
        copyHint.textContent = 'Click "Copy" or select all and copy manually.';
        copyHint.style.color = '#888';
      }
    }

    function closeShareModal() {
      shareModal.style.display = 'none';
      copyHint.textContent = '';
      copyBtn.textContent = 'Copy';
    }

    if (shareBtn) shareBtn.onclick = openShareModal;
    if (modalClose) modalClose.onclick = closeShareModal;
    if (shareModal) shareModal.onclick = (e) => { if (e.target === shareModal) closeShareModal(); };
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeShareModal(); });

    if (copyBtn) {
      copyBtn.onclick = () => {
        const text = shareUrlInput.value;
        shareUrlInput.select();
        shareUrlInput.setSelectionRange(0, 99999);
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(text)
            .then(() => { copyBtn.textContent = 'Copied ✓'; copyHint.textContent = 'Link copied!'; copyHint.style.color = '#22c55e'; setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000); })
            .catch(() => { document.execCommand('copy'); copyBtn.textContent = 'Copied ✓'; setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000); });
        } else {
          document.execCommand('copy');
          copyBtn.textContent = 'Copied ✓';
          copyHint.textContent = 'Link copied!';
          copyHint.style.color = '#22c55e';
          setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
        }
      };
    }

    fetchWishlist();
  })();
</script>

